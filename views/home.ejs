      <h2>✏️ Actualizar Celular</h2>
      <div style="margin: 20px 0;">
        <label style="display: block; margin-bottom: 10px;">
          <strong>Nuevo celular:</strong>
          <input type="text" id="newCelularInput" placeholder="3XXXXXXXXX, 573XXXXXXXXX o +573XXXXXXXXX" style="width: 100%; padding: 10px; margin-top: 5px; border: 1px solid #ddd; border-radius: 4px;" />
        </label>
      </div>

      <div id="updateProgress" style="margin: 20px 0; display: none;">
        <h3 style="margin-bottom: 15px;">Progreso de actualización:</h3>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          <div style="display: flex; align-items: center; gap: 10px;">
            <span id="crmStatus" style="font-size: 1.5em;">⏳</span>
            <span><strong>CRM (ActiveCampaign):</strong> <span id="crmMessage">Esperando...</span></span>
          </div>
          <div style="display: flex; align-items: center; gap: 10px;">
            <span id="strapiStatus" style="font-size: 1.5em;">⏳</span>
            <span><strong>Strapi Carteras:</strong> <span id="strapiMessage">Esperando...</span></span>
          </div>
          <div style="display: flex; align-items: center; gap: 10px;">
            <span id="fr360Status" style="font-size: 1.5em;">⏳</span>
            <span><strong>FR360 Links:</strong> <span id="fr360Message">Esperando...</span></span>
          </div>
        </div>
      </div>

      <div class="modal-actions">
        <button type="button" id="cancelEditCelular">❌ Cancelar</button>
        <button type="button" id="confirmEditCelular">✅ Actualizar</button>
      </div>
    </div>
  </div>

