<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FR360</title>
  <link rel="icon" type="image/png" href="/favicon.png?v=3" />
  <link
    href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/styles.css?v=<%= Date.now() %>" />
</head>
<body>
  <!-- Botón hamburguesa para móvil -->
  <button id="menuToggle" aria-label="Abrir menú">☰</button>

  <!-- SIDEBAR -->
  <aside id="sidebar">
    <div class="logo">
      <img
        src="/fr360-logo.png"
        alt="FR360 Logo"
        class="logo-img"
      />
    </div>
    <nav>
      <ul>
        <li data-tab="comercialito" class="active">Comercialito</li>
        <li data-tab="membresias">Planes</li>
        <li data-tab="ventas">Ventas</li>
        <li data-tab="acuerdos">Acuerdos</li>
        <li data-tab="links">Links</li>
        <li class="nav-section-title">Utilidades</li>
        <li data-tab="webpig">Web Pig 🐷</li>
        <% if (typeof userEmail !== 'undefined' && ['daniel.cardona@sentiretaller.com', 'yicela.agudelo@sentiretaller.com', 'ana.quintero@sentiretaller.com'].includes(userEmail)) { %>
        <li data-tab="epayco">ePayco 💳</li>
        <% } %>
        <% if (typeof userEmail !== 'undefined' && ['daniel.cardona@sentiretaller.com', 'juan.pelaez@sentiretaller.com', 'alex.lopez@sentiretaller.com'].includes(userEmail)) { %>
        <li data-tab="finanzas-2026">Finanzas 2026 📈</li>
        <% } %>
        <%# <li data-tab="anticipados-2026">Anticipados 2026</li> %>
        <% if (typeof userEmail !== 'undefined' && userEmail === 'daniel.cardona@sentiretaller.com') { %>
        <li data-tab="carteras-masivo">Carteras Masivo 📊</li>
        <% } %>
      </ul>
    </nav>
  </aside>

  <!-- MAIN -->
  <div id="main">
    <!-- TOPBAR -->
    <div id="topbar">
      <input type="text" id="searchId" placeholder="Ingrese Nro ID, correo o celular…" />
      <button type="button" id="searchBtn"><span class="btn-text-desktop">Buscar</span><span class="btn-text-mobile">🔍</span></button>
      <div id="statusTop"></div>
      <button id="crmBtn" onclick="window.open('https://script.google.com/a/macros/sentiretaller.com/s/AKfycbyVMunmRcMMgyQjzFHYO3LHahrfWRTEMUnNnRrGHZ6tM-N-BDW8u-qx9jdxdaB_tNXe/exec', '_blank')" style="margin-left:auto; background:#007bff; color:white; border:none; padding:8px 16px; border-radius:4px; cursor:pointer; font-weight:600;" title="Abrir CRM"><span class="btn-text-mobile">📊</span><span class="btn-text-desktop">📊 CRM</span></button>
      <button id="ticketBtn" style="margin-left:12px; background:#28a745; color:white; border:none; padding:8px 16px; border-radius:4px; cursor:pointer; font-weight:600;" title="Crear ticket"><span class="btn-text-mobile">💡</span><span class="btn-text-desktop">💡 Sugerir mejora</span></button>
      <div id="currentUser" style="margin-left:12px; font-size:0.9em; color:#666;"></div>
    </div>

    <!-- CONTENT -->
    <div id="content">
      <!-- COMERCIALITO -->
      <div class="pane left active" id="comercialito">
        <div class="comercialito-layout">
          <!-- VENTA NORMAL (IZQUIERDA) -->
          <div class="venta-normal">
            <h3 style="margin-top: 0; margin-bottom: 20px; color: #075183;">Venta normal <button type="button" id="clearFormBtn" style="margin-left: 10px; padding: 4px 10px; font-size: 0.75em; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;" title="Borrar datos y reiniciar">🗑️ Borrar</button> <span id="clientTypeIndicator" style="display: none; font-size: 0.75em; margin-left: 10px; padding: 4px 10px; border-radius: 4px;"></span> <span id="moraIndicator" style="display: none; color: #dc3545; font-size: 0.9em; margin-left: 5px;">⚠️ En mora</span></h3>
            <div class="form-row">
              <span class="label">Nombres:</span>
              <div class="input-wrapper">
                <input id="nombres" class="input gray"/>
                <button type="button" id="copyNombres" class="copy-icon" data-copy-target="nombres" style="display:none;" title="Copiar">📋</button>
              </div>
            </div>
            <div class="form-row">
              <span class="label">Apellidos:</span>
              <div class="input-wrapper">
                <input id="apellidos" class="input gray"/>
                <button type="button" id="copyApellidos" class="copy-icon" data-copy-target="apellidos" style="display:none;" title="Copiar">📋</button>
              </div>
            </div>
            <div class="form-row">
              <span class="label">Correo:</span>
              <div class="input-wrapper">
                <input id="correo" class="input" />
                <button type="button" id="copyCorreo" class="copy-icon" data-copy-target="correo" style="display:none;" title="Copiar">📋</button>
              </div>
            </div>
            <div class="form-row">
              <span class="label">Celular:</span>
              <div class="input-wrapper">
                <input id="celular" class="input" />
                <button type="button" id="editCelularBtn" class="edit-celular-icon" style="display:none;" title="Editar celular">✏️</button>
                <span id="callbellIcon" class="callbell-icon" style="display:none;">🛎️</span>
                <button type="button" id="copyCelular" class="copy-icon" data-copy-target="celular" style="display:none;" title="Copiar">📋</button>
              </div>
            </div>
            <div class="form-row">
              <span class="label">Producto:</span>
              <input id="producto" class="input" list="productosList" autocomplete="off" />
              <datalist id="productosList"></datalist>
            </div>
            <div class="form-row hidden" id="row-nro-acuerdo">
              <span class="label">Nro de acuerdo:</span>
              <input id="nroAcuerdoComercialito" class="input" />
            </div>
            <div class="form-row hidden" id="row-cuotas">
              <span class="label">Nro de cuotas:</span>
              <select id="cuotas" class="input">
                <option value="" disabled selected>Selecciona la cantidad de cuotas</option>
              </select>
            </div>
            <div class="form-row" id="row-valor">
              <span class="label">Valor:</span>
              <input id="valor" class="input" />
            </div>
            <div class="form-row hidden" id="row-inicio">
              <span class="label">Inicio plataforma:</span>
              <div class="inicio-container" style="flex: 1; display: flex; flex-direction: column; gap: 8px;">
                <select id="inicioTipo" class="input">
                  <option value="" disabled selected>Selecciona el tipo de inicio</option>
                  <option value="primer-pago">Con primer pago</option>
                  <option value="fecha-personalizada">Fecha personalizada</option>
                </select>
                <input type="date" id="inicio" class="input" style="display: none;" />
              </div>
            </div>
            <div class="form-row hidden" id="row-fecha-max">
              <span class="label">Fecha máxima:</span>
              <input
                type="date"
                id="fechaMax"
                class="input"
                placeholder="Indica hasta qué día estará disponible el link de pago"
              />
            </div>
            <div class="form-row" id="row-comercial">
              <span class="label">Comercial:</span>
              <select id="comercial" class="input">
                <option value="" disabled selected>Selecciona tu nombre</option>
                <option>Álex David López Jaramillo</option>
                <option>Ana Isabel Arango Goez</option>
                <option>Ángela Yirley Silva David</option>
                <option>Angélica Solórzano Torres</option>
                <option>Daniel Mauricio Cardona Alzate</option>
                <option>Eliana Marcela Montilla De La Cruz</option>
                <option>Giancarlo Aguilar Fonnegra</option>
                <option>Santiago Flórez Rojo</option>
              </select>
            </div>
            <!-- Plan de pagos -->
            <div id="planPagosContainer" class="hidden">
              <h3 style="margin-top: 20px; color: #075183;">Plan de pagos</h3>
              <table id="planPagosTable">
                <thead>
                  <tr>
                    <th>Nro de cuota</th>
                    <th>Fecha</th>
                    <th>Valor cuota</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
            <!-- Botón Crear link debajo del Plan de pagos -->
            <div class="form-row hidden" id="row-link-btn">
              <button id="createLinkBtn" class="input">Crear link</button>
            </div>
            <div id="linkResult" style="margin-top:8px;"></div>
          </div>

          <!-- VENTA EN CONFIANZA (DERECHA) -->
          <div class="venta-confianza-section">
            <h3 style="margin-top: 0; margin-bottom: 20px;">Venta en confianza</h3>
            <div class="form-row">
              <span class="label">Nombres:</span>
              <input id="nombresConfianza" class="input gray"/>
            </div>
            <div class="form-row">
              <span class="label">Apellidos:</span>
              <input id="apellidosConfianza" class="input gray"/>
            </div>
            <div class="form-row">
              <span class="label">Correo:</span>
              <input id="correoConfianza" class="input" readonly style="background-color: #f5f5f5; cursor: not-allowed;" title="Campo automático: se alimenta de datos del sistema" />
            </div>
            <div class="form-row">
              <span class="label">Celular:</span>
              <input id="celularConfianza" class="input" readonly style="background-color: #f5f5f5; cursor: not-allowed;" title="Campo automático: se alimenta de datos del sistema" />
            </div>
            <div class="form-row">
              <span class="label">Nro Acuerdo:</span>
              <div style="display: flex; gap: 8px;">
                <input id="nroAcuerdo" class="input" placeholder="Ingrese número de acuerdo" autocomplete="new-password" />
                <button id="buscarAcuerdoBtn">🔍 Buscar acuerdo</button>
              </div>
            </div>

            <!-- Campos deshabilitados que se poblarán con la consulta del acuerdo -->
            <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #ddd;">
              <div class="form-row">
                <span class="label">Producto:</span>
                <input id="productoAcuerdo" class="input" disabled style="background-color: #f5f5f5;"/>
              </div>
              <div class="form-row">
                <span class="label">Comercial:</span>
                <input id="comercialAcuerdo" class="input" disabled style="background-color: #f5f5f5;"/>
              </div>
              <div class="form-row">
                <span class="label">Fecha inicio:</span>
                <input id="fechaInicioAcuerdo" class="input" disabled style="background-color: #f5f5f5;"/>
              </div>
              <div class="form-row">
                <span class="label">Estado:</span>
                <input id="estadoAcuerdo" class="input" disabled style="background-color: #f5f5f5;"/>
              </div>
              <!-- Botón Otorgar acceso en confianza -->
              <button id="otorgarAccesoBtn">🤝 Otorgar acceso en confianza</button>

              <!-- Campo URL de activación (inicialmente oculto) -->
              <div id="urlActivacionSection" style="display: none; margin-top: 15px; padding-top: 15px; border-top: 1px solid #ddd;">
                <div class="form-row">
                  <span class="label">URL de activación:</span>
                  <div style="display: flex; gap: 8px;">
                    <input id="urlActivacion" class="input" disabled style="background-color: #f5f5f5; flex: 1;" placeholder="Se generará automáticamente tras el registro exitoso"/>
                    <button id="copiarUrlBtn" disabled style="white-space: nowrap;">📋 Copiar</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- OTRAS PESTAÑAS -->
      <div class="pane right" id="membresias">
      <div class="memb-layout">
        <!-- Plataforma vieja (oculta visualmente, consulta sigue activa) -->
        <div class="memb-old" style="display:none;">
          <h3 style="margin-top: 20px; color: #075183;">Plataforma vieja</h3>
          <div id="membOldContainer"></div>
        </div>

        <!-- CENTRO: FRAPP -->
        <div class="memb-new">
          <div class="memb-new-header" style="display:flex;align-items:center;justify-content:flex-start;margin-bottom:8px;gap:8px;">
            <h3 style="margin-top: 20px; color: #075183;">Plataforma nueva</h3>
            <button id="editUserBtn" style="display:none;background:none;border:none;font-size:1.2em;cursor:pointer;padding:4px;margin-top:20px;" title="Editar usuario">✏️</button>
          </div>
          <div id="membNewContainer"></div>
          <div style="margin-top:12px;">
            <button id="addMembBtn" style="padding:6px 12px;font-size:1em;cursor:pointer;">
              ➕ Agregar plan
            </button>
          </div>
        </div>

        <!-- DERECHA: Acciones (estrecha) -->
        <div class="memb-actions">
          <h3 style="margin-top: 20px; color: #075183;">Acciones</h3>
          <button id="batchOpenBtn" class="batch-btn" title="Agregar planes en lote">
            ➕➕ Agregar planes<br>en lote
          </button>
          <!-- aquí en el futuro puedes sumar más botones/acciones -->
        </div>
      </div>

      <div id="membresiasContainer"></div>
    </div>
      <div class="pane right" id="ventas">
        <div id="ventasContainer"></div>
        <div id="discountAnalysis" style="margin-top:16px"></div>
      </div>
      <div class="pane right" id="acuerdos">
        <div id="acuerdosContainer"></div>
      </div>
      <div class="pane right" id="links">
        <h3 id="linksTitle" style="display:none">Links</h3>
        <div id="linksContainer"></div>
      </div>

      <!-- WEB PIG -->
      <div class="pane right" id="webpig">
        <div class="webpig-fixed-header">
          <div class="webpig-header">
            <h3 id="webpigTitle">Web Pig 🐷 - Transacciones Recientes <span id="webpigEffectiveness" style="font-size: 0.85em; color: #999; font-weight: normal;"></span></h3>
            <div style="display:flex;gap:8px;align-items:center;">
              <button id="volverWebPigBtn" class="btn-primary" style="background:#e91e63;display:none;">⬅️ Volver a Web Pig</button>
              <button id="ventasCCBtn" class="btn-primary" style="background:#e65100;">💴 Ventas en cuenta corriente</button>
              <button id="refreshWebhooksBtn" class="btn-primary">🔄 Actualizar transacciones</button>
            </div>
          </div>
          <div class="webpig-controls">
            <div class="feature-flags-container">
              <div class="feature-flag-item">
                <span class="flag-label">Crear membresías</span>
                <label class="toggle-switch">
                  <input type="checkbox" id="flag-FRAPP_MEMBERSHIP_ENABLED" data-flag="FRAPP_MEMBERSHIP_ENABLED" disabled>
                  <span class="slider"></span>
                </label>
              </div>
              <div class="feature-flag-item">
                <span class="flag-label">Facturar</span>
                <label class="toggle-switch">
                  <input type="checkbox" id="flag-WORLDOFFICE_INVOICE_ENABLED" data-flag="WORLDOFFICE_INVOICE_ENABLED" disabled>
                  <span class="slider"></span>
                </label>
              </div>
              <div class="feature-flag-item">
                <span class="flag-label">Emitir DIAN</span>
                <label class="toggle-switch">
                  <input type="checkbox" id="flag-WORLDOFFICE_DIAN_ENABLED" data-flag="WORLDOFFICE_DIAN_ENABLED" disabled>
                  <span class="slider"></span>
                </label>
              </div>
            </div>
            <div id="flagsErrorMsg" class="flags-error-msg" style="display: none;"></div>
          </div>
        </div>
        <div id="webpigContainer"></div>
      </div>

      <!-- EPAYCO (solo visible para daniel.cardona, yicela.agudelo, ana.quintero) -->
      <% if (typeof userEmail !== 'undefined' && ['daniel.cardona@sentiretaller.com', 'yicela.agudelo@sentiretaller.com', 'ana.quintero@sentiretaller.com'].includes(userEmail)) { %>
      <div class="pane right" id="epayco">
        <div class="webpig-fixed-header">
          <div class="webpig-header">
            <h3>ePayco 💳 - Últimas 100 Transacciones</h3>
            <button id="refreshEpaycoBtn" class="btn-primary">🔄 Actualizar transacciones</button>
          </div>
        </div>
        <div id="epaycoContainer"></div>
      </div>
      <% } %>

      <!-- FINANZAS 2026 (solo para usuarios autorizados) -->
      <% if (typeof userEmail !== 'undefined' && ['daniel.cardona@sentiretaller.com', 'juan.pelaez@sentiretaller.com', 'alex.lopez@sentiretaller.com'].includes(userEmail)) { %>
      <div class="pane right" id="finanzas-2026">
        <div class="finanzas-header">
          <h2>Finanzas 2026 📈</h2>
          <button id="loadFinanzasBtn" class="btn-primary">🔄 Cargar Datos</button>
          <button id="loadCarteraBtn" class="btn-primary" style="background: #6c5ce7; margin-left: 10px;">💰 Cartera</button>
        </div>
        <div id="finanzasContainer" style="margin-top: 20px;">
          <p style="color: #666;">Haz clic en "Cargar Datos" para ver la comparación de facturación.</p>
        </div>
      </div>
      <% } %>

      <!-- ANTICIPADOS 2026 (oculto) -->
      <%# <div class="pane right" id="anticipados-2026">
        <div class="udea-header">
          <h2>Anticipados 2026 💰</h2>
          <button id="loadAnticipadosBtn" class="btn-primary">🔄 Cargar Anticipados</button>
          <button id="downloadAnticipadosBtn" class="btn-primary" style="display: none; background: #28a745;">📥 Descargar CSV</button>
        </div>
        <div id="anticipadosStatsContainer" class="udea-stats" style="display: none;">
          <div class="stat-card">
            <h3>Total Estudiantes</h3>
            <p id="anticipadosTotalEstudiantes" class="stat-value">0</p>
          </div>
          <div class="stat-card">
            <h3>Total Adeudado</h3>
            <p id="anticipadosTotalAdeudado" class="stat-value">$0</p>
          </div>
          <div class="stat-card">
            <h3>Solo Al Día</h3>
            <p id="anticipadosTotalAlDia" class="stat-value">$0</p>
          </div>
        </div>
        <div id="anticipadosStatusContainer" style="margin: 20px 0; padding: 15px; background: #f8f9fa; border-radius: 8px; display: none;">
          <p id="anticipadosStatus" style="margin: 0; color: #333;"></p>
        </div>
        <div id="anticipadosTableContainer"></div>
      </div> %>

      <!-- ACTUALIZACIÓN MASIVA DE CARTERAS (solo visible para daniel.cardona@sentiretaller.com) -->
      <% if (typeof userEmail !== 'undefined' && userEmail === 'daniel.cardona@sentiretaller.com') { %>
      <div class="pane right" id="carteras-masivo">
        <div class="carteras-masivo-header">
          <h2>Actualización Masiva de Carteras 📊</h2>
          <p style="color: #666; margin-bottom: 16px;">
            Procesa TODAS las cuotas pendientes y vencidas:<br>
            • Cuotas con estado_pago = null<br>
            • Cuotas con estado_pago = 'al_dia' pero con fecha_limite &lt; hoy<br>
            • Opcionalmente: cuotas en mora para verificar si ya fueron pagadas
          </p>
          <div class="carteras-masivo-controls">
            <div style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap; margin-bottom: 12px;">
              <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                <input type="checkbox" id="incluirMoraCheckbox" style="width: 18px; height: 18px; cursor: pointer;">
                <span style="font-weight: 500;">Incluir cartera en mora</span>
              </label>
            </div>
            <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
              <button id="startCarterasMasivoBtn" class="btn-primary">▶️ Iniciar Procesamiento Global</button>
              <button id="stopCarterasMasivoBtn" class="btn-danger" style="display: none;">⏹️ Detener</button>
            </div>
            <div id="carterasProgress" style="margin-top: 12px; display: none;">
              <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: #e3f2fd; border-radius: 8px; border-left: 4px solid #2196f3;">
                <div class="spinner" style="width: 20px; height: 20px; border: 3px solid #e3f2fd; border-top: 3px solid #2196f3; border-radius: 50%; animation: spin 1s linear infinite;"></div>
                <span id="carterasProgressText" style="font-weight: 600; font-size: 0.9em; color: #1976d2;">Procesando carteras...</span>
              </div>
            </div>
            <style>
              @keyframes spin {
                0% { transform: rotate(0deg); }
                100% { transform: rotate(360deg); }
              }
            </style>
          </div>
        </div>
        <div id="carterasResultsContainer" style="margin-top: 20px; max-height: 600px; overflow-y: auto;"></div>

        <!-- Sección Desbloqueo de Al días -->
        <div class="desbloqueo-section" style="margin-top: 32px; padding-top: 24px; border-top: 2px solid #dee2e6;">
          <h3 style="margin-bottom: 12px;">🔓 Desbloqueo de Al días</h3>
          <p style="color: #666; margin-bottom: 16px;">
            Busca usuarios bloqueados que ya están al día y permite desbloquearlos:<br>
            • Verifica que todas las cuotas tengan mora ≤ 5 días<br>
            • Quita rol "moroso" en WordPress y FRAPP<br>
            • Notifica al Google Chat de cobranza
          </p>
          <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <button id="buscarMorososBtn" class="btn-success">🔍 Buscar Al días Bloqueados</button>
          </div>
          <div id="desbloqueoStatus" style="margin-top: 12px; display: none;">
            <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: #e3f2fd; border-radius: 8px; border-left: 4px solid #2196f3;">
              <div class="spinner" style="width: 20px; height: 20px; border: 3px solid #e3f2fd; border-top: 3px solid #2196f3; border-radius: 50%; animation: spin 1s linear infinite;"></div>
              <span id="desbloqueoStatusText" style="font-weight: 600; font-size: 0.9em; color: #1976d2;">Buscando morosos...</span>
            </div>
          </div>
          <div id="desbloqueoResultsContainer" style="margin-top: 16px;"></div>
        </div>

        <!-- Sección Bloqueo de Morosos -->
        <div class="bloqueo-section" style="margin-top: 32px; padding-top: 24px; border-top: 2px solid #dee2e6;">
          <h3 style="margin-bottom: 12px;">🔒 Bloqueo de Morosos</h3>
          <p style="color: #666; margin-bottom: 16px;">
            Busca usuarios activos con cuotas en mora grave (>= 6 días) y permite bloquearlos:<br>
            • Asigna rol "moroso" en WordPress<br>
            • Cambia status a "moroso" en FRAPP<br>
            • Registra en Strapi y notifica al Google Chat<br>
            • Actualiza CRM y envía WhatsApp por Callbell
          </p>
          <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <button id="buscarParaBloqueoBtn" class="btn-danger">🔍 Buscar Candidatos a Bloqueo</button>
          </div>
          <div id="bloqueoStatus" style="margin-top: 12px; display: none;">
            <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: #fff3cd; border-radius: 8px; border-left: 4px solid #ffc107;">
              <div class="spinner" style="width: 20px; height: 20px; border: 3px solid #fff3cd; border-top: 3px solid #ffc107; border-radius: 50%; animation: spin 1s linear infinite;"></div>
              <span id="bloqueoStatusText" style="font-weight: 600; font-size: 0.9em; color: #856404;">Buscando candidatos...</span>
            </div>
          </div>
          <div id="bloqueoResultsContainer" style="margin-top: 16px;"></div>
        </div>

        <!-- Sección Cobrancio Web (Notificaciones de cobranza) -->
        <div class="cobrancio-section" style="margin-top: 32px; padding-top: 24px; border-top: 2px solid #dee2e6;">
          <h3 style="margin-bottom: 12px;">📱 Cobrancio Web - Notificaciones</h3>
          <p style="color: #666; margin-bottom: 16px;">
            Envía notificaciones de cobranza vía WhatsApp (Callbell) y registra en Strapi:<br>
            • <strong>MORA:</strong> Usuarios con 3-5 días de mora<br>
            • <strong>FECHA:</strong> Cuotas que vencen hoy, mañana o pasado mañana (si son festivos)<br>
            • <strong>PREVIO:</strong> Cuotas que vencen en 7 días
          </p>

          <!-- Botones principales -->
          <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 16px;">
            <button id="cobrancioFullBtn" class="btn-primary" style="background: #6f42c1;">🚀 Ejecutar Cobrancio FULL</button>
            <button id="cobrancioResumenBtn" class="btn-primary" style="background: #17a2b8;">📊 Ver Resumen</button>
          </div>

          <!-- Botones individuales -->
          <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
            <button id="cobrancioMoraBtn" class="btn-warning" style="background: #fd7e14; border-color: #fd7e14;">⏰ MORA (3-5 días)</button>
            <button id="cobrancioFechaBtn" class="btn-info" style="background: #20c997; border-color: #20c997;">📅 FECHA (hoy/mañana)</button>
            <button id="cobrancioPrevioBtn" class="btn-secondary" style="background: #6c757d; border-color: #6c757d;">📆 PREVIO (7 días)</button>
          </div>

          <!-- Status -->
          <div id="cobrancioStatus" style="margin-top: 12px; display: none;">
            <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: #e8f4f8; border-radius: 8px; border-left: 4px solid #17a2b8;">
              <div class="spinner" style="width: 20px; height: 20px; border: 3px solid #e8f4f8; border-top: 3px solid #17a2b8; border-radius: 50%; animation: spin 1s linear infinite;"></div>
              <span id="cobrancioStatusText" style="font-weight: 600; font-size: 0.9em; color: #0c5460;">Procesando...</span>
            </div>
          </div>

          <!-- Resumen de candidatos -->
          <div id="cobrancioResumenContainer" style="margin-top: 16px; display: none;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
              <div style="padding: 16px; background: #fff3cd; border-radius: 8px; border-left: 4px solid #ffc107;">
                <h4 style="margin: 0 0 8px 0; color: #856404;">⏰ MORA</h4>
                <p style="margin: 0; font-size: 1.5em; font-weight: 700; color: #856404;" id="cobrancioMoraCount">0</p>
                <small style="color: #856404;">candidatos (3-5 días)</small>
              </div>
              <div style="padding: 16px; background: #d4edda; border-radius: 8px; border-left: 4px solid #28a745;">
                <h4 style="margin: 0 0 8px 0; color: #155724;">📅 FECHA</h4>
                <p style="margin: 0; font-size: 1.5em; font-weight: 700; color: #155724;" id="cobrancioFechaCount">0</p>
                <small style="color: #155724;" id="cobrancioFechaDetail">hoy: 0</small>
              </div>
              <div style="padding: 16px; background: #cce5ff; border-radius: 8px; border-left: 4px solid #007bff;">
                <h4 style="margin: 0 0 8px 0; color: #004085;">📆 PREVIO</h4>
                <p style="margin: 0; font-size: 1.5em; font-weight: 700; color: #004085;" id="cobrancioPrevioCount">0</p>
                <small style="color: #004085;" id="cobrancioPrevioDetail">7 días antes</small>
              </div>
            </div>
          </div>

          <!-- Contenedor de resultados -->
          <div id="cobrancioResultsContainer" style="margin-top: 16px;"></div>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <!-- ====== Modal para "Agregar plan" ====== -->
  <div id="addMembModal" class="modal hidden">
    <div class="modal-backdrop"></div>
    <div class="modal-dialog">
      <h3>➕ Agregar plan</h3>
      <div id="modalResponse" class="modal-response" style="margin-bottom:12px;color:#333;display:none;"></div>
      <form id="addMembForm">
        <!-- Email -->
        <div class="modal-row">
          <label for="modalEmail">Correo</label>
          <input type="email" id="modalEmail" required />
        </div>
        <!-- Nombres -->
        <div class="modal-row">
          <label for="modalGiven">Nombres</label>
          <input type="text" id="modalGiven" required />
        </div>
        <!-- Apellidos -->
        <div class="modal-row">
          <label for="modalFamily">Apellidos</label>
          <input type="text" id="modalFamily" required />
        </div>
        <!-- Celular -->
        <div class="modal-row">
          <label for="modalPhone">Celular</label>
          <input type="tel" id="modalPhone" required />
        </div>
        <div class="modal-row">
          <label for="modalEvento">Justificación</label>
          <textarea id="modalEvento" required rows="2"></textarea>
        </div>
        <!-- Plan -->
        <div class="modal-row">
          <label for="modalHandle">Plan</label>
          <select id="modalHandle" required>
            <option value="" disabled selected>Cargando planes...</option>
          </select>
        </div>
        <!-- Fecha inicio -->
        <div class="modal-row">
          <label for="modalStart">Fecha inicio</label>
          <input type="date" id="modalStart" required />
        </div>
        <!-- Duración (días) -->
        <div class="modal-row">
          <label for="modalDuration">Duración (días)</label>
          <input type="number" id="modalDuration" min="1" required />
        </div>
        <!-- Fecha fin -->
        <div class="modal-row">
          <label for="modalExpiry">Fecha fin</label>
          <input type="date" id="modalExpiry" required />
        </div>
        <!-- Botones -->
        <div class="modal-actions">
          <button type="button" id="cancelAddMemb">❌ Cancelar</button>
          <button type="submit">✅ Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal para Editar usuario de FRAPP -->
  <div id="editUserModal" class="modal hidden">
    <div class="modal-backdrop"></div>
    <div class="modal-dialog">
      <h3>✏️ Editar usuario - Plataforma nueva</h3>
      <div id="editUserResponse" class="modal-response" style="margin-bottom:12px;color:#333;display:none;"></div>
      <form id="editUserForm">
        <input type="hidden" id="editUserId" />

        <!-- Campos editables -->
        <div class="modal-row">
          <label for="editUserEmail">Email *</label>
          <input type="email" id="editUserEmail" required />
        </div>

        <div class="modal-row">
          <label for="editUserGivenName">Nombres *</label>
          <input type="text" id="editUserGivenName" required />
        </div>

        <div class="modal-row">
          <label for="editUserFamilyName">Apellidos *</label>
          <input type="text" id="editUserFamilyName" required />
        </div>

        <div class="modal-row">
          <label for="editUserIdentityDocument">Cédula *</label>
          <input type="text" id="editUserIdentityDocument" required />
        </div>

        <!-- Campos no editables (solo lectura) -->
        <div class="modal-row">
          <label for="editUserPhone">Teléfono (solo lectura)</label>
          <input type="text" id="editUserPhone" readonly style="background-color: #f5f5f5; cursor: not-allowed;" />
        </div>

        <div class="modal-row">
          <label for="editUserBirthdate">Fecha nacimiento (solo lectura)</label>
          <input type="text" id="editUserBirthdate" readonly style="background-color: #f5f5f5; cursor: not-allowed;" />
        </div>

        <div class="modal-row">
          <label for="editUserGender">Género (solo lectura)</label>
          <input type="text" id="editUserGender" readonly style="background-color: #f5f5f5; cursor: not-allowed;" />
        </div>

        <div class="modal-row">
          <label for="editUserIdentityType">Tipo documento (solo lectura)</label>
          <input type="text" id="editUserIdentityType" readonly style="background-color: #f5f5f5; cursor: not-allowed;" />
        </div>

        <div class="modal-row">
          <label for="editUserTimezone">Timezone (solo lectura)</label>
          <input type="text" id="editUserTimezone" readonly style="background-color: #f5f5f5; cursor: not-allowed;" />
        </div>

        <div class="modal-row">
          <label for="editUserStatus">Estado (solo lectura)</label>
          <input type="text" id="editUserStatus" readonly style="background-color: #f5f5f5; cursor: not-allowed;" />
        </div>

        <!-- Botones -->
        <div class="modal-actions">
          <button type="button" id="cancelEditUser">❌ Cancelar</button>
          <button type="submit">✅ Guardar cambios</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal para Congelar membresía -->
  <div id="freezeModal" class="modal hidden">
    <div class="modal-backdrop"></div>
    <div class="modal-dialog">
      <h3>🥶 Congelar membresía</h3>
      <form id="freezeForm">
        <div class="modal-row">
          <label for="freezeReason">Motivo</label>
          <input type="text" id="freezeReason" required />
        </div>
        <div class="modal-row">
          <label for="freezeDate">Desde</label>
          <input type="date" id="freezeDate" required />
        </div>
        <div class="modal-row">
          <label for="unfreezeDate">Hasta</label>
          <input type="date" id="unfreezeDate" required />
        </div>
        <div class="modal-row">
          <label for="daysRemaining">Días restantes</label>
          <input type="number" id="daysRemaining" readonly />
        </div>
        <div class="modal-actions">
          <button type="button" id="cancelFreeze">❌ Cancelar</button>
          <button type="submit">🥶 Congelar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal de confirmación -->
  <div id="freezeSuccessModal" class="modal hidden">
    <div class="modal-backdrop"></div>
    <div class="modal-dialog">
      <h3>✅ Congelación exitosa</h3>
      <div class="modal-actions">
        <button id="closeFreezeSuccess">Aceptar</button>
      </div>
    </div>
  </div>

  <!-- Modal: Agregar planes en lote -->
    <div id="batchModal" class="modal hidden">
      <div class="modal-backdrop"></div>
      <div class="modal-dialog" style="width:900px;max-width:95vw">
        <h3>➕➕ Agregar planes en lote</h3>

        <!-- Plan -->
        <div class="modal-row">
          <label for="batchProduct">Plan</label>
          <select id="batchProduct" required>
            <option value="" disabled selected>Cargando planes...</option>
          </select>
        </div>

        <!-- Fecha inicio -->
        <div class="modal-row">
          <label for="batchStart">Fecha inicio</label>
          <input type="date" id="batchStart" required />
        </div>

        <!-- Duración (días) -->
        <div class="modal-row">
          <label for="batchDuration">Duración (días)</label>
          <input type="number" id="batchDuration" min="1" required />
        </div>

        <!-- Fecha fin -->
        <div class="modal-row">
          <label for="batchExpiry">Fecha fin</label>
          <input type="date" id="batchExpiry" required />
        </div>

        <div class="batch-grid">
          <div class="batch-col">
            <label><strong>Cédulas</strong></label>
            <textarea id="batchCedulas" placeholder="Una cédula por línea"></textarea>
            <div class="mini">Se ignorarán duplicados y caracteres no numéricos.</div>
          </div>
          <div class="batch-col">
            <button id="batchValidateBtn">📧 Validar emails</button>
            <div id="batchResults" class="box" aria-live="polite">
              <ul id="batchResultsList" class="pair-list"></ul>
            </div>
          </div>
          <div class="batch-col">
            <button id="batchAddBtn">➕➕ Agregar planes</button>
            <button id="batchPauseBtn" disabled>⏸️ Pausar</button>
            <div id="batchAddStatus" class="box" aria-live="polite">
              <ul id="batchAddList" class="pair-list"></ul>
            </div>
          </div>
        </div>

        <div class="modal-actions">
          <button type="button" id="batchCloseBtn">Cerrar</button>
        </div>
      </div>
    </div>

  <!-- Modal para Crear Ticket en ClickUp -->
  <div id="ticketModal" class="modal hidden">
    <div class="modal-backdrop"></div>
    <div class="modal-dialog">
      <h3>💡 Sugerir mejora o reportar problema</h3>
      <p style="margin-bottom:16px; color:#666; font-size:0.9em;">
        Usa este formulario para reportar bugs, solicitar cambios o proponer nuevas funciones para FR360.
      </p>
      <div id="ticketResponse" class="modal-response" style="margin-bottom:12px;color:#333;display:none;"></div>
      <form id="ticketForm">
        <!-- Título -->
        <div class="modal-row">
          <label for="ticketTitle">Título *</label>
          <input type="text" id="ticketTitle" placeholder="Ej: Error al cargar membresías" required maxlength="100" />
        </div>

        <!-- Tipo -->
        <div class="modal-row">
          <label for="ticketType">Tipo *</label>
          <select id="ticketType" required>
            <option value="">Seleccione...</option>
            <option value="Bug">🐛 Bug (algo no funciona)</option>
            <option value="Mejora">✨ Mejora (optimizar algo existente)</option>
            <option value="Nueva función">🚀 Nueva función</option>
            <option value="Cambio">🔄 Cambio (modificar funcionalidad)</option>
          </select>
        </div>

        <!-- Prioridad -->
        <div class="modal-row">
          <label for="ticketPriority">Prioridad *</label>
          <select id="ticketPriority" required>
            <option value="baja">🟢 Baja</option>
            <option value="media" selected>🟡 Media</option>
            <option value="alta">🟠 Alta</option>
            <option value="urgente">🔴 Urgente</option>
          </select>
        </div>

        <!-- Descripción -->
        <div class="modal-row">
          <label for="ticketDescription">Descripción detallada *</label>
          <textarea
            id="ticketDescription"
            placeholder="Describe el problema o la mejora que propones. Incluye pasos para reproducir si es un bug."
            required
            rows="6"
            maxlength="2000"
          ></textarea>
          <div style="font-size:0.8em; color:#999; margin-top:4px;">
            <span id="ticketCharCount">0</span> / 2000 caracteres
          </div>
        </div>

        <!-- Botones -->
        <div class="modal-actions">
          <button type="button" id="cancelTicket">❌ Cancelar</button>
          <button type="submit">📤 Enviar ticket</button>
        </div>
      </form>
    </div>
  </div>

