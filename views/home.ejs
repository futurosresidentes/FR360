    <div class="modal-content" style="max-width: 800px;">
      <h2 id="stageDetailsTitle">Detalles del Stage</h2>
      <div id="stageDetailsBody" style="max-height: 500px; overflow-y: auto;">
        <!-- Content will be populated by JavaScript -->
